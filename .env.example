# .env.example — copy to .env and fill in your SQL Server credentials.
# This file is safe to commit: it contains only placeholders, never real values.
# .env is gitignored, so secrets stay local only.
MSSQL_CONNECTION_STRING=Server=<your-server>;Database=<your-database>;User Id=<your-username>;Password=<your-password>;Encrypt=True;TrustServerCertificate=True;
