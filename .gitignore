*.DS_Store
*.swp
*~

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# npm
# NOTE: npm/bin/mssql-mcp is intentionally NOT ignored. The committed file is a
# Node.js shim that makes `npx mssql-mcp` work immediately after install. The
# postinstall script (npm/install.js) overwrites it with the real native binary
# downloaded from GitHub Releases. Developers who run `npm install` locally will
# see `npm/bin/mssql-mcp` show as modified in git status — restore the shim with
# `git checkout -- npm/bin/mssql-mcp`. See ADR-0002 (sqz pattern) and ADR-0014.
npm/node_modules/
npm/bin/mssql-mcp.exe
npm/*.tgz

# Publish output
publish/
artifacts/

# Logs
*.log

# OS
Thumbs.db
Desktop.ini

# Local env files
.env
.env.local

# Azure SQL Edge (integration test data)
azure-sql-edge-data/

# OpenCode session state
.omo/
