#!/usr/bin/env node
// Shim: replaced by the real binary during npm install (postinstall).
// If you see this message, the postinstall did not run or the download failed.
const { spawnSync } = require('child_process');
const path = require('path');
const fs = require('fs');
const binPath = path.join(__dirname, 'mssql-mcp');
if (fs.existsSync(binPath) && !fs.readFileSync(binPath, 'utf8').includes('Shim')) {
  const result = spawnSync(binPath, process.argv.slice(2), { stdio: 'inherit' });
  process.exit(result.status ?? 1);
} else {
  console.error('mssql-mcp: binary not installed. Run "npm install" or use "dotnet tool install -g mssql-mcp" instead.');
  process.exit(1);
}
