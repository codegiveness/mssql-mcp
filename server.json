{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codegiveness/mssql-mcp",
  "title": "mssql-mcp",
  "description": "MCP server for SQL Server. Lets AI agents safely query SQL Server via a controlled tool surface.",
  "version": "0.4.1",
  "repository": {
    "url": "https://github.com/codegiveness/mssql-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@codegiveness/mssql-mcp",
      "version": "0.4.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MSSQL_CONNECTION_STRING",
          "description": "SQL Server connection string",
          "isRequired": true,
          "isSecret": true
        }
      ]
    },
    {
      "registryType": "nuget",
      "registryBaseUrl": "https://api.nuget.org/v3/index.json",
      "identifier": "codegiveness.mssql-mcp",
      "version": "0.4.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MSSQL_CONNECTION_STRING",
          "description": "SQL Server connection string",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
